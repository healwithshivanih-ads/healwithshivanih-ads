# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# ── Gmail (for "Send to client" email) ────────────────────────────────────────
# Create a Google App Password (not your normal Gmail password):
# https://myaccount.google.com/apppasswords
GMAIL_USER=your.gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── AiSensy (WhatsApp outbound + webhook) ─────────────────────────────────────
# Find your API key in AiSensy → Settings → API
AISENSY_API_KEY=your_aisensy_api_key
# Secret token for the inbound webhook endpoint (/api/aisensy-webhook)
AISENSY_WEBHOOK_SECRET=choose_a_random_secret

# ── Path overrides (optional — defaults shown) ────────────────────────────────
# FMDB_PLANS_DIR=/home/youruser/fm-plans
# FMDB_CATALOGUE_DIR=/path/to/fm-database/data
# FMDB_RESOURCES_DIR=/home/youruser/fm-resources

# ── Public base URL (for canonical links in emails etc.) ──────────────────────
# NEXT_PUBLIC_BASE_URL=http://localhost:3002
