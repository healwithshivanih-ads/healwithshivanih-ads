# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# ── Gmail (for "Send to client" email) ────────────────────────────────────────
# Create a Google App Password (not your normal Gmail password):
# https://myaccount.google.com/apppasswords
GMAIL_USER=your.gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Self-hosted WhatsApp Cloud API server ────────────────────────────────────
# AiSensy is decommissioned (v0.74). Outbound + inbound now go via the
# self-hosted server. Templates registered via whatsapp-server/scripts/submit-templates.js.
WHATSAPP_SERVER_URL=https://your-whatsapp-server
WHATSAPP_SERVER_API_KEY=your_server_api_key

# ── Path overrides (optional — defaults shown) ────────────────────────────────
# FMDB_PLANS_DIR=/home/youruser/fm-plans
# FMDB_CATALOGUE_DIR=/path/to/fm-database/data
# FMDB_RESOURCES_DIR=/home/youruser/fm-resources

# ── Public origin (REQUIRED for intake-form links + start-confirm + handover) ─
# Server actions in intake.ts / handover.ts / cron refuse to send links if
# this is unset or points to localhost (the link would be unreachable from
# the client's phone). Set to the public origin of the intake form.
NEXT_PUBLIC_APP_URL=https://intake.theochretree.com
