# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# ── Gmail (for "Send to client" email) ────────────────────────────────────────
# Create a Google App Password (not your normal Gmail password):
# https://myaccount.google.com/apppasswords
GMAIL_USER=your.gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── WhatsApp self-hosted Cloud API (whatsapp-server-shivani on Fly) ──────────
# AiSensy was fully decommissioned 2026-05-15 — fm-coach now talks to the
# self-hosted WA Cloud API server for both outbound (templates + free-text)
# and inbound (HMAC-verified webhook → /api/whatsapp-webhook here).
#
# WHATSAPP_SERVER_URL points at the Fly app, WHATSAPP_SERVER_API_KEY is the
# shared bearer token (also set on the WA server as ADMIN_API_KEY). The
# webhook secret is set on the WA server as FM_COACH_WEBHOOK_SECRET and
# must match the WHATSAPP_WEBHOOK_SECRET we verify inbound with.
WHATSAPP_SERVER_URL=https://whatsapp-server-shivani.fly.dev
WHATSAPP_SERVER_API_KEY=your_shared_admin_token
WHATSAPP_WEBHOOK_SECRET=your_shared_webhook_secret

# ── Recipe inbox (forward reels/photos/PDFs to the coach WhatsApp number) ─────
# Comma-separated phone numbers (the coach's PERSONAL phone(s), matched on the
# last 10 digits). Every inbound WhatsApp message from these numbers is staged
# as a recipe candidate in ~/fm-plans/_recipe_inbox/ for review at /recipes —
# never saved as a client note. The webhook runs on the Fly app, so set this
# there too: flyctl secrets set RECIPE_INBOX_NUMBERS=919876543210 -a theochretree-coach
# RECIPE_INBOX_NUMBERS=919876543210

# ── Coach notification phone (for cal.com booking alerts via WhatsApp) ─────────
# Your own WhatsApp number in E.164 format. Used by coach_booking_alert_v1 to
# send you an instant WhatsApp whenever a cal.com booking is created / rescheduled
# / cancelled. Falls back to GMAIL_USER email if this is not set.
COACH_NOTIFY_PHONE=+919876543210

# ── Path overrides (optional — defaults shown) ────────────────────────────────
# FMDB_PLANS_DIR=/home/youruser/fm-plans
# FMDB_CATALOGUE_DIR=/path/to/fm-database/data
# FMDB_RESOURCES_DIR=/home/youruser/fm-resources

# ── Public base URL (for canonical links in emails etc.) ──────────────────────
# NEXT_PUBLIC_BASE_URL=http://localhost:3002

# Authorize API-spending shims (set to 1 in the app; chat shells omit it).
FM_API_OK=1

# ── Revenue export → ochre-funnel (growth-system Loop 1) ──────────────────────
# fm-coach POSTs payment / programme_completed / active_client_count events to
# the marketing app so funnels are judged on LTV, not just tickets, and ads
# pause when the coach is at capacity. Contract: docs/REVENUE_EXPORT_CONTRACT.md
# Unset → every emit is a silent no-op (the outbox still records for backfill).
# OCHRE_FUNNEL_REVENUE_URL=https://ochre-funnel.fly.dev/api/webhooks/fm-coach-revenue
# FM_REVENUE_EXPORT_SECRET=shared_hmac_secret_same_as_ochre_funnel_FM_COACH_REVENUE_SECRET
# Capacity config travels IN the events (the coach owns her cap).
# The practice holds 100 active clients; the weekly throttle is 20 NEW
# SIGNUPS (trailing 7 days) — that's what gates lead-buying.
# FM_MAX_ACTIVE_CLIENTS=100
# FM_MAX_SIGNUPS_PER_WEEK=20
# FM_DISCOVERY_CALLS_PER_WEEK=8
