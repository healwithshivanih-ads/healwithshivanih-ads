{
  "name": "whatsapp-server",
  "version": "1.0.0",
  "description": "WhatsApp Cloud API webhook server with admin UI",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "build:ui": "cd admin-ui && npm install && npm run build",
    "build": "npm run build:ui",
    "postinstall": "echo 'Run: npm run build:ui to build the admin UI'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "node-fetch": "^3.3.2",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "dotenv": "^16.4.5",
    "cors": "^2.8.5"
  },
  "engines": {
    "node": ">=20"
  }
}
