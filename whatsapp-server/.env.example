# --- Meta WhatsApp Cloud API ---
# Permanent system-user access token from Meta App > WhatsApp > API setup
WHATSAPP_TOKEN=EAAG...

# WhatsApp phone number ID (Meta App > WhatsApp > API setup)
PHONE_NUMBER_ID=1234567890

# WhatsApp Business Account ID
WHATSAPP_BUSINESS_ACCOUNT_ID=1234567890

# Webhook verify token — you pick this; must match what you paste into Meta's webhook config
VERIFY_TOKEN=pick-any-long-random-string

# App secret from Meta App > Settings > Basic — used to verify X-Hub-Signature-256
META_APP_SECRET=abc123...

# --- Supabase ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Admin API ---
# Any long random string. Send as `x-api-key` header on all /api/* requests.
ADMIN_API_KEY=generate-a-strong-random-string

# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Public base URL (used in webhook setup docs and external integrations)
BASE_URL=https://your-app.fly.dev

# --- Optional ---
# Calendly webhook signing secret (from Calendly webhooks dashboard)
CALENDLY_SIGNING_SECRET=

# Cal.com webhook signing secret (set when adding the webhook in Cal.com)
CAL_COM_SIGNING_SECRET=

# Wix webhook secret (validate inbound payloads — currently coarse header check)
WIX_WEBHOOK_SECRET=

# Encryption key for integrations.credentials_encrypted (Wix API key etc.).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INTEGRATION_ENCRYPTION_KEY=
