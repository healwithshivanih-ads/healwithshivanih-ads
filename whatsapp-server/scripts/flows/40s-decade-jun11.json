{
  "version": "7.0",
  "data_api_version": "3.0",
  "routing_model": {
    "WELCOME": []
  },
  "screens": [
    {
      "id": "WELCOME",
      "title": "Heal With Shivani",
      "terminal": true,
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Hey 👋 glad you're here."
          },
          {
            "type": "TextBody",
            "text": "I'm Shivani. This is my next workshop — 40s: The Decade No One Prepared You For.\n\nWired at 3am. Tired at 4pm. Not crazy. Not lazy. Just unprepared.\n\n📅 Thu 11 June · 7:00 PM IST\n🎟 ₹199 · 60 min on Zoom\n\nA few quick things and I'll send you the registration link:"
          },
          {
            "type": "Form",
            "name": "lead_form",
            "init-values": {
              "first_name": "",
              "email": ""
            },
            "children": [
              {
                "type": "TextInput",
                "name": "first_name",
                "label": "What should I call you?",
                "helper-text": "Optional — leave blank if you'd rather skip"
              },
              {
                "type": "TextInput",
                "name": "email",
                "label": "Your email",
                "helper-text": "Optional — I'll send the recording here if you can't make it live",
                "input-type": "email"
              },
              {
                "type": "Dropdown",
                "name": "concern",
                "label": "What's bothering you the most right now?",
                "required": true,
                "data-source": [
                  { "id": "sleep", "title": "Sleep — I'm up at 3am" },
                  { "id": "energy", "title": "Energy — crashing by 4pm" },
                  { "id": "weight", "title": "Weight — middle's creeping up" },
                  { "id": "mood", "title": "Mood — irritable, hot flashes" },
                  { "id": "all", "title": "Honestly, all of it" }
                ]
              },
              {
                "type": "Footer",
                "label": "Send me the link 🌿",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "first_name": "${form.first_name}",
                    "email": "${form.email}",
                    "concern": "${form.concern}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
